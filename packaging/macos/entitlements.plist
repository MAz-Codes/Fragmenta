<?xml version="1.0" encoding="UTF-8"?>
<!--
Hardened-runtime entitlements for Fragmenta.

Fragmenta ships a standalone Python and pip-installs torch/SA3 at first run.
Those dylibs are downloaded on the user's machine and are NOT signed by us, so
the hardened runtime must relax library validation, and torch/numba JIT needs
executable-memory entitlements. Without these, a notarized build crashes the
moment it loads an unsigned pip-installed .dylib.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
